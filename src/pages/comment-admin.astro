---
import CommentAdmin from "@features/comments/components/CommentAdmin";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="评论管理" description="管理待审核的博客评论">
  <main class="mx-auto w-full max-w-4xl px-4 py-10 sm:px-6">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight">评论管理</h1>
      <p class="mt-2 text-sm text-muted-foreground">审核、发布或删除博客评论</p>
    </div>
    <CommentAdmin client:load />
  </main>
</BaseLayout>
