---
import ThreeColumnLayout from "@layouts/ThreeColumnLayout.astro";
import WakaDashboard from "@features/waka/components/WakaDashboard";
import LeetcodeStats from "@features/leetcode-stats/components/LeetcodeStats";
import LeftSidebar from "@components/widgets/LeftSidebar.astro";
import RightSidebar from "@components/widgets/RightSidebar.astro";
import { getPostsData } from "@src/hooks/usePostsData";
import { CREATE_TIME } from "@src/consts";

const { totalPostsCounts, totalPostsWords, totalTagsCounts } =
  await getPostsData();

const siteData = {
  createTime: CREATE_TIME,
  articleCount: totalPostsCounts,
  tagCount: totalTagsCounts,
  wordCount: totalPostsWords,
};
---

<ThreeColumnLayout title="状态" description="个人状态与数据统计">
  <LeftSidebar slot="left-sidebar" />

  <main class="w-full mx-auto">
    <div class="mb-10 px-1">
      <h1 class="text-3xl font-extrabold tracking-tight text-foreground">
        状态面板
      </h1>
      <p class="mt-2 text-sm text-muted-foreground">个人数据追踪</p>
    </div>

    <WakaDashboard client:load />

    <div class="my-12 border-t border-border" role="separator"></div>

    <LeetcodeStats client:load />
  </main>

  <RightSidebar slot="right-sidebar" siteData={siteData} />
</ThreeColumnLayout>
