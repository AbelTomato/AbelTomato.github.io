---
import ThreeColumnLayout from "@layouts/ThreeColumnLayout.astro";
import LeftSidebar from "@components/widgets/LeftSidebar.astro";
import RightSidebar from "@components/widgets/RightSidebar.astro";
import { getPostsData } from "@src/hooks/usePostsData";
import { CREATE_TIME } from "@src/consts";
import { Card, CardHeader, CardTitle, CardContent } from "@components/ui/card";

const { totalPostsCounts, totalTagsCounts, totalPostsWords } =
  await getPostsData();

const siteData = {
  createTime: CREATE_TIME,
  articleCount: totalPostsCounts,
  tagCount: totalTagsCounts,
  wordCount: totalPostsWords,
};
---

<ThreeColumnLayout
  title="关于我"
  description="认识一下 AbelTomato —— 一个想让自己变得有趣的人"
>
  <LeftSidebar slot="left-sidebar" />

  <main class="w-full flex flex-col gap-6">
    <Card className="w-full mx-auto shadow-sm">
      <CardHeader className="pb-4">
        <div class="text-center md:text-left">
          <h1
            class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100"
          >
            一个番茄
          </h1>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
            Last updated: March 1, 2026
          </p>
          <hr
            class="mt-4 w-16 border-t-2 border-blue-500 dark:border-blue-400"
          />
        </div>
      </CardHeader>

      <CardContent
        className="w-full mx-auto prose prose-gray dark:prose-invert max-w-none"
      >
        <p>你好，我是AbelTomato</p>

        <h2>关于名字</h2>
        <p><strong>Abel:</strong></p>
        <p class="pl-4 border-l-2 border-gray-200 dark:border-gray-700">
          是我初中时外教要求大家起的英文名，然后我在网上随便找了个字典序靠前的。后面第一节外教课把名字报上去，刚下课我就忘了自己名字叫什么了，冲出教室冲着外教背影大喊：“What's
          my name?!”传为众人笑谈，沿用至今。
        </p>

        <p><strong>Tomato:</strong></p>
        <p class="pl-4 border-l-2 border-gray-200 dark:border-gray-700">
          没什么特别的原因，只是因为我喜欢吃番茄。其实改成AbelPotato也是可以的。
        </p>

        <hr />

        <h2>个人简介</h2>
        <p>XMU大一学生，学校里平平无奇的一个人</p>
        <p>
          梦想是赚<strong>很多</strong
          >钱，然后过一种平平淡淡无忧无虑的生活，可以随便做自己喜欢的事，而无需被裹挟
        </p>
        <p>创建这个博客，大概是为了练手，以及记录一些想法和生活</p>
        <p>如果博客中的内容有帮助到你，我很荣幸</p>
      </CardContent>
    </Card>
  </main>

  <RightSidebar slot="right-sidebar" siteData={siteData} />
</ThreeColumnLayout>
