---
// src/pages/index.astro
import ThreeColumnLayout from "@layouts/ThreeColumnLayout.astro";
import { SITE_TITLE, SITE_DESCRIPTION, CREATE_TIME } from "../consts";
import FormattedDate from "@components/ui/FormattedDate.astro";
import { Image } from "astro:assets";
import placeholderImg from "../../public/android-chrome-512x512.png";
import LeftSidebar from "@components/widgets/LeftSidebar.astro";
import RightSidebar from "@components/widgets/RightSidebar.astro";
import { getPostsData } from "@src/hooks/usePostsData";

const { recentPosts, totalTagsCounts, totalPostsCounts, totalPostsWords } =
  await getPostsData();

const siteData = {
  createTime: CREATE_TIME,
  articleCount: totalPostsCounts,
  tagCount: totalTagsCounts,
  wordCount: totalPostsWords,
};
---

<ThreeColumnLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <LeftSidebar slot="left-sidebar" />

  <main class="container mx-auto px-4 py-12">
    <section
      class="flex flex-col items-center justify-center text-center mb-16"
    >
      <h1
        class="text-4xl md:text-5xl font-bold mb-4 text-gray-900 dark:text-gray-100"
      >
        你好，我是 <span class="text-blue-600 dark:text-blue-400"
          >AbelTomato</span
        >
      </h1>
      <p class="text-lg text-muted-foreground max-w-lg mb-8">
        {SITE_DESCRIPTION}
      </p>
    </section>

    <section class="mb-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
          最近文章
        </h2>
        <a
          href="/blog"
          class="group inline-flex items-center gap-1.5 rounded-full border border-blue-300 dark:border-blue-700 px-4 py-1.5 text-sm font-medium text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-950 hover:border-blue-400 dark:hover:border-blue-500 transition-colors"
        >
          查看全部
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="w-4 h-4 transition-transform group-hover:translate-x-0.5"
          >
            <path
              fill-rule="evenodd"
              d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>

      <div class="flex flex-col gap-4">
        {
          recentPosts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="group block bg-white dark:bg-gray-800/50 rounded-xl border border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all duration-200 overflow-hidden"
            >
              <article class="grid grid-cols-[1fr_auto] p-0">
                <div class="flex flex-col sm:flex-row gap-4 p-5">
                  <div class="sm:w-28 shrink-0 text-sm text-muted-foreground font-mono pt-0.5">
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors mb-1 line-clamp-1">
                      {post.data.title}
                    </h3>
                    <p class="text-sm text-muted-foreground line-clamp-2 mb-3">
                      {post.data.description}
                    </p>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {post.data.tags.slice(0, 4).map((tag: string) => (
                          <span class="inline-block px-2 py-0.5 text-xs rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
                <div class="w-32 sm:w-44 bg-gray-100 dark:bg-gray-700">
                  {post.data.heroImage ? (
                    <Image
                      src={post.data.heroImage}
                      alt={post.data.title}
                      width={352}
                      height={240}
                      format="avif"
                      quality={80}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  ) : (
                    <Image
                      src={placeholderImg}
                      alt="placeholder"
                      width={352}
                      height={240}
                      format="avif"
                      quality={80}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover"
                    />
                  )}
                </div>
              </article>
            </a>
          ))
        }
      </div>
    </section>
  </main>

  <RightSidebar slot="right-sidebar" siteData={siteData} />
</ThreeColumnLayout>
