---
import ThreeColumnLayout from "@layouts/ThreeColumnLayout.astro";
import { getPostsData } from "@src/hooks/usePostsData";
import LeftSidebar from "@components/widgets/LeftSidebar.astro";
import RightSidebar from "@components/widgets/RightSidebar.astro";
import { CREATE_TIME } from "@src/consts";

import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const pageSize = 12;
  const {
    posts,
    allTags,
    tagCountsMap,
    maxCount,
    minCount,
    totalPostsCounts,
    totalPostsWords,
    totalTagsCounts,
  } = await getPostsData();

  const lastPage = Math.ceil(posts.length / pageSize);

  return Array.from({ length: Math.max(lastPage - 1, 0) }, (_, index) => {
    const currentPage = index + 2;

    return {
      params: { page: String(currentPage) },
      props: {
        pagePosts: posts.slice(
          (currentPage - 1) * pageSize,
          currentPage * pageSize,
        ),
        currentPage,
        lastPage,
        allTags,
        tagCountsMap,
        maxCount,
        minCount,
        totalPostsCounts,
        totalPostsWords,
        totalTagsCounts,
      },
    };
  });
}

interface Props {
  pagePosts: CollectionEntry<"blog">[];
  currentPage: number;
  lastPage: number;
  allTags: string[];
  tagCountsMap: Record<string, number>;
  maxCount: number;
  minCount: number;
  totalPostsCounts: number;
  totalPostsWords: number;
  totalTagsCounts: number;
}

const {
  pagePosts,
  currentPage,
  lastPage,
  allTags,
  tagCountsMap,
  maxCount,
  minCount,
  totalPostsCounts,
  totalPostsWords,
  totalTagsCounts,
} = Astro.props;

const pageNumbers = Array.from({ length: lastPage }, (_, index) => index + 1);

const siteData = {
  createTime: CREATE_TIME,
  articleCount: totalPostsCounts,
  tagCount: totalTagsCounts,
  wordCount: totalPostsWords,
};
---

<ThreeColumnLayout
  title={`Blog - 第 ${currentPage} 页`}
  description={`浏览 AbelTomato's Blog 的所有文章，第 ${currentPage} 页`}
>
  <LeftSidebar slot="left-sidebar" />

  <main class="py-12 container mx-auto px-4">
    <h1
      class="text-4xl md:text-5xl font-bold text-center mb-8 text-gray-900 dark:text-gray-100"
    >
      Blog
    </h1>

    <div
      class="flex flex-wrap justify-center items-center gap-4 mb-16 max-w-3xl mx-auto"
    >
      {
        allTags.map((tag) => {
          const count = tagCountsMap[tag];
          const weight =
            maxCount === minCount
              ? 0
              : (count - minCount) / (maxCount - minCount);

          const fontSize =
            weight > 0.8
              ? "text-2xl"
              : weight > 0.5
                ? "text-xl"
                : weight > 0.2
                  ? "text-lg"
                  : "text-sm";

          const opacity = 0.4 + weight * 0.6;

          return (
            <a
              href={`/tags/${tag}`}
              class={`inline-block font-bold transition-[transform,color] duration-200 hover:scale-110 hover:text-blue-600 dark:hover:text-blue-400 will-change-transform ${fontSize}`}
              style={`opacity: ${opacity};`}
            >
              <span class="text-blue-500/50 mr-0.5">#</span>
              {tag}
              <sup class="text-[10px] ml-0.5 font-mono opacity-50">{count}</sup>
            </a>
          );
        })
      }
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        pagePosts.map((post) => (
          <div class="group bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow border border-gray-100 dark:border-gray-700">
            <a href={`/blog/${post.id}/`} class="block">
              {post.data.heroImage && (
                <div class="overflow-hidden aspect-video">
                  <img
                    src={post.data.heroImage.src}
                    alt={post.data.title}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              )}

              <div class="p-6">
                {post.data.tags && (
                  <div class="flex flex-wrap gap-2 mb-3">
                    {post.data.tags.map((tag) => (
                      <span class="text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                <h2 class="text-xl font-bold mb-2 text-gray-900 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  {post.data.title}
                </h2>

                <p class="text-gray-600 dark:text-gray-400 mb-4 line-clamp-2 text-sm">
                  {post.data.description}
                </p>

                <time class="text-xs text-gray-400 dark:text-gray-500 font-mono">
                  {post.data.pubDate.toLocaleDateString("zh-CN", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
            </a>
          </div>
        ))
      }
    </div>

    <nav
      class="mt-12 flex flex-wrap items-center justify-center gap-2"
      aria-label="博客分页"
    >
      {
        pageNumbers.map((pageNumber) => (
          <a
            href={pageNumber === 1 ? "/blog/" : `/blog/${pageNumber}/`}
            aria-current={pageNumber === currentPage ? "page" : undefined}
            class={`min-w-10 rounded-xl border px-3 py-2 text-center text-sm font-medium shadow-sm transition-colors ${
              pageNumber === currentPage
                ? "border-blue-500 bg-blue-500 text-white"
                : "border-gray-200 bg-white text-gray-700 hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-700"
            }`}
          >
            {pageNumber}
          </a>
        ))
      }
    </nav>
  </main>

  <RightSidebar slot="right-sidebar" siteData={siteData} />
</ThreeColumnLayout>
