---
// src/layouts/BlogPost.astro
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@components/ui/FormattedDate.astro";
import ArticleChangelog from "@components/blog/ArticleChangelog.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import type { MarkdownHeading } from "astro";
import TableOfContents from "@components/TableOfContents.astro";
import CommentSection from "@features/comments/components/CommentSection";

type Props = CollectionEntry<"blog">["data"] & {
  slug: string;
  count?: number;
  minutes?: number;
  headings?: MarkdownHeading[];
  comments?: boolean;
  previousPost?: CollectionEntry<"blog">;
  nextPost?: CollectionEntry<"blog">;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  slug,
  count,
  minutes,
  headings = [],
  comments = true,
  changelog = [],
  previousPost,
  nextPost,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="reading-progress" aria-hidden="true"><span></span></div>
  <main class="max-w-350 mx-auto px-4 py-8">
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_768px_1fr] gap-12 items-start"
    >
      <div class="hidden lg:block"></div>

      <article class="min-h-[60vh] w-full" data-article>
        {
          heroImage && (
            <div class="hero-image mb-8">
              <Image
                width={1020}
                height={510}
                src={heroImage}
                alt={title}
                class="w-full rounded-xl shadow-2xl object-cover"
              />
            </div>
          )
        }

        <div
          class="prose prose-slate prose-lg md:prose-xl dark:prose-invert mx-auto max-w-none prose-headings:scroll-mt-24"
        >
          <header class="text-center mb-12">
            <h1
              class="text-4xl md:text-5xl font-bold mb-4 text-gray-900 dark:text-gray-100"
            >
              {title}
            </h1>
            <div class="text-gray-600 dark:text-gray-400 space-y-2">
              <time><FormattedDate date={pubDate} /></time>
              {
                updatedDate && (
                  <p class="italic">
                    最后更新：<FormattedDate date={updatedDate} />
                  </p>
                )
              }
            </div>
          </header>

          <hr class="my-10 border-gray-300 dark:border-gray-700" />

          {
            count && minutes && (
              <div class="flex items-center justify-center gap-6 text-sm text-gray-500 mt-4 mb-8">
                <span class="flex items-center gap-1">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-files"
                  >
                    <path d="M20 7h-3a2 2 0 0 1-2-2V2" />
                    <path d="M9 18a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h7l4 4v10a2 2 0 0 1-2 2Z" />
                    <path d="M3 7v10a2 2 0 0 0 2 2h10" />
                  </svg>
                  {count} 字
                </span>
                <span class="flex items-center gap-1">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-clock"
                  >
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </svg>
                  约 {minutes} 分钟
                </span>
              </div>
            )
          }

          <div data-article-content><slot /></div>
        </div>

        <ArticleChangelog changelog={changelog} />

        {
          (previousPost || nextPost) && (
            <nav class="article-pagination" aria-label="文章导航">
              {previousPost ? (
                <a href={`/blog/${previousPost.id}`} class="article-pagination__item">
                  <span class="article-pagination__eyebrow">
                    <span class="article-pagination__arrow" aria-hidden="true">←</span>
                    上一篇
                  </span>
                  <span class="article-pagination__tag">
                    {previousPost.data.tags?.[0] ?? "文章"}
                  </span>
                  <strong>{previousPost.data.title}</strong>
                  <span class="article-pagination__description">{previousPost.data.description}</span>
                  <time class="article-pagination__meta" datetime={previousPost.data.pubDate.toISOString()}>
                    <FormattedDate date={previousPost.data.pubDate} />
                  </time>
                </a>
              ) : <div />}
              {nextPost ? (
                <a href={`/blog/${nextPost.id}`} class="article-pagination__item article-pagination__item--next">
                  <span class="article-pagination__eyebrow">
                    下一篇
                    <span class="article-pagination__arrow" aria-hidden="true">→</span>
                  </span>
                  <span class="article-pagination__tag">
                    {nextPost.data.tags?.[0] ?? "文章"}
                  </span>
                  <strong>{nextPost.data.title}</strong>
                  <span class="article-pagination__description">{nextPost.data.description}</span>
                  <time class="article-pagination__meta" datetime={nextPost.data.pubDate.toISOString()}>
                    <FormattedDate date={nextPost.data.pubDate} />
                  </time>
                </a>
              ) : <div />}
            </nav>
          )
        }

        {comments && <CommentSection resourceId={slug} client:load />}
      </article>

      <div class="hidden lg:block sticky top-24">
        <TableOfContents headings={headings} />
      </div>
    </div>
  </main>
  <dialog class="image-lightbox" aria-label="图片预览">
    <button class="image-lightbox__close" type="button" aria-label="关闭图片预览">×</button>
    <button class="image-lightbox__previous" type="button" aria-label="查看上一张图片">‹</button>
    <img alt="" />
    <button class="image-lightbox__next" type="button" aria-label="查看下一张图片">›</button>
    <a class="image-lightbox__original" target="_blank" rel="noreferrer">查看原图</a>
  </dialog>
</BaseLayout>

<script>
  const initializeCodeBlockToggles = () => {
    document.querySelectorAll<HTMLElement>(".code-block__body > pre").forEach((pre) => {
      if (pre.querySelector(".code-block__line-numbers")) return;
      const code = pre.querySelector("code");
      if (!code) return;
      const lines = Math.max(1, (code.textContent ?? "").replace(/\n$/, "").split("\n").length);
      const numbers = document.createElement("span");
      numbers.className = "code-block__line-numbers";
      numbers.setAttribute("aria-hidden", "true");
      numbers.textContent = Array.from({ length: lines }, (_, index) => String(index + 1)).join("\n");
      pre.prepend(numbers);
    });

    const toggles = document.querySelectorAll<HTMLButtonElement>(
      ".code-block__toggle:not([data-code-toggle-ready])",
    );

    toggles.forEach((toggle) => {
      toggle.dataset.codeToggleReady = "true";
      toggle.querySelectorAll("svg").forEach((icon) => icon.remove());

      let toggleText = toggle.querySelector<HTMLElement>(
        ".code-block__toggle-text",
      );

      if (!toggleText) {
        const text = toggle.textContent?.trim() || "收起";

        toggle.textContent = "";
        toggleText = document.createElement("span");
        toggleText.className = "code-block__toggle-text";
        toggleText.textContent = text;
        toggle.append(toggleText);
      }

      if (!toggle.querySelector(".code-block__toggle-mark")) {
        const toggleMark = document.createElement("span");
        toggleMark.className = "code-block__toggle-mark";
        toggleMark.setAttribute("aria-hidden", "true");
        toggle.append(toggleMark);
      }

      toggle.addEventListener("click", () => {
        const codeBlock = toggle.closest<HTMLElement>(".code-block");

        if (!codeBlock) {
          return;
        }

        const collapsed = codeBlock.dataset.collapsed === "true";
        const nextCollapsed = !collapsed;
        const toggleText = toggle.querySelector<HTMLElement>(
          ".code-block__toggle-text",
        );

        codeBlock.dataset.collapsed = String(nextCollapsed);
        toggle.setAttribute("aria-expanded", String(!nextCollapsed));
        toggle.setAttribute(
          "aria-label",
          nextCollapsed ? "展开代码块" : "收起代码块",
        );

        if (toggleText) {
          toggleText.textContent = nextCollapsed ? "展开" : "收起";
        }
      });
    });

    document.querySelectorAll<HTMLButtonElement>(".code-block__copy:not([data-code-copy-ready])").forEach((button) => {
      button.dataset.codeCopyReady = "true";
      button.addEventListener("click", async () => {
        const code = button.closest(".code-block")?.querySelector("pre code")?.textContent ?? "";
        try {
          await navigator.clipboard.writeText(code);
          button.textContent = "已复制";
        } catch {
          button.textContent = "复制失败";
        }
        window.setTimeout(() => { button.textContent = "复制"; }, 1600);
      });
    });
  };

  const initializeReadingEnhancements = () => {
    const article = document.querySelector<HTMLElement>("[data-article-content]");
    const progress = document.querySelector<HTMLElement>(".reading-progress > span");
    if (!article || !progress || article.dataset.enhanced === "true") return;
    article.dataset.enhanced = "true";

    const updateProgress = () => {
      const rect = article.getBoundingClientRect();
      const total = Math.max(article.offsetHeight - window.innerHeight * 0.6, 1);
      progress.style.width = `${Math.min(100, Math.max(0, (-rect.top + window.innerHeight * 0.25) / total * 100))}%`;
    };
    updateProgress();
    window.addEventListener("scroll", updateProgress, { passive: true });

    const links = [...document.querySelectorAll<HTMLAnchorElement>(".toc-link")];
    const headings = [...article.querySelectorAll<HTMLElement>("h2[id], h3[id], h4[id], h5[id], h6[id]")];
    const setActive = (id: string) => links.forEach((link) => {
      const active = link.hash === `#${id}`;
      link.classList.toggle("is-active", active);
      if (active) link.scrollIntoView({ block: "nearest" });
    });
    const observer = new IntersectionObserver((entries) => {
      const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
      if (visible) setActive((visible.target as HTMLElement).id);
    }, { rootMargin: "-18% 0px -68% 0px", threshold: 0 });
    headings.forEach((heading) => observer.observe(heading));

    const images = [...article.querySelectorAll<HTMLImageElement>("img")];
    const dialog = document.querySelector<HTMLDialogElement>(".image-lightbox");
    const dialogImage = dialog?.querySelector<HTMLImageElement>("img");
    const original = dialog?.querySelector<HTMLAnchorElement>(".image-lightbox__original");
    let index = 0;
    const openImage = (nextIndex: number) => {
      if (!dialog || !dialogImage || !original || images.length === 0) return;
      index = (nextIndex + images.length) % images.length;
      const image = images[index];
      dialogImage.src = image.currentSrc || image.src;
      dialogImage.alt = image.alt;
      original.href = dialogImage.src;
      dialog.showModal();
    };
    images.forEach((image, imageIndex) => {
      image.classList.add("article-image");
      image.addEventListener("click", () => openImage(imageIndex));
    });
    dialog?.querySelector(".image-lightbox__close")?.addEventListener("click", () => dialog.close());
    dialog?.querySelector(".image-lightbox__previous")?.addEventListener("click", () => openImage(index - 1));
    dialog?.querySelector(".image-lightbox__next")?.addEventListener("click", () => openImage(index + 1));
    dialog?.addEventListener("click", (event) => { if (event.target === dialog) dialog.close(); });
  };

  const initializeArticlePage = () => {
    initializeCodeBlockToggles();
    initializeReadingEnhancements();
  };
  document.addEventListener("astro:page-load", initializeArticlePage);
  initializeArticlePage();
</script>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  .prose :is(h2, h3, h4, h5, h6) {
    scroll-margin-top: 5rem;
  }
</style>
