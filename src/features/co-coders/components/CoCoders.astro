---
import { type Friend, friendsList } from "../data/friends";
import { Image } from "astro:assets";
---

<div class="mt-12 space-y-8">
  <h2
    class="text-3xl font-bold mb-10 flex items-center gap-3 text-gray-900 dark:text-gray-100"
  >
    <span class="text-blue-500">🤝</span> 一些有趣的朋友
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {
      friendsList.map((f) => (
        <a
          href={f.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative block overflow-hidden rounded-2xl aspect-21/9 shadow-xl transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl bg-gray-200 dark:bg-gray-700"
        >
          <Image
            src={f.cover}
            alt={`${f.name} 的封面`}
            width={800}
            height={380}
            format="avif"
            quality={75}
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />

          <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent" />

          <div class="absolute inset-0 p-6 flex items-end">
            <div class="flex items-center gap-4 w-full">
              <Image
                src={f.avatar}
                alt={`${f.name} 的头像`}
                width={48}
                height={48}
                format="avif"
                quality={80}
                loading="lazy"
                class="w-12 h-12 rounded-full border-2 border-white/50 shadow-md object-cover shrink-0 bg-white"
              />
              <div class="flex-1 text-white min-w-0">
                <h3 class="text-xl font-bold group-hover:text-blue-300 transition-colors truncate">
                  {f.name}
                </h3>
                <p class="text-sm text-gray-200 mt-1 line-clamp-1 opacity-90 group-hover:opacity-100 transition-opacity">
                  {f.description}
                </p>
              </div>
              <span class="text-2xl text-white/50 group-hover:text-white transition-all transform group-hover:translate-x-1">
                →
              </span>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</div>
