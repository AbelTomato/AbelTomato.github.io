---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  post: CollectionEntry<"blog">;
  eager?: boolean;
}

const { post, eager = false } = Astro.props;
---

<article
  class="group overflow-hidden rounded-xl border border-gray-200/70 bg-white/70 shadow-lg backdrop-blur-xl transition-shadow hover:shadow-xl dark:border-gray-700/70 dark:bg-gray-800/70"
>
  <a href={`/blog/${post.id}/`} class="block">
    {
      post.data.heroImage && (
        <div class="aspect-video overflow-hidden bg-gray-100 dark:bg-gray-700">
          <Image
            src={post.data.heroImage}
            alt={post.data.title}
            width={480}
            height={270}
            format="avif"
            quality={76}
            loading={eager ? "eager" : "lazy"}
            decoding="async"
            class="h-full w-full object-cover transition-opacity duration-200 group-hover:opacity-95"
          />
        </div>
      )
    }

    <div class="p-6">
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="mb-3 flex max-h-12 flex-wrap gap-2 overflow-hidden">
            {post.data.tags.map((tag: string) => (
              <span class="rounded bg-gray-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-gray-500 dark:bg-gray-700 dark:text-gray-400">
                {tag}
              </span>
            ))}
          </div>
        )
      }

      <h2 class="mb-2 text-xl font-bold text-gray-900 transition-colors group-hover:text-blue-600 dark:text-gray-100 dark:group-hover:text-blue-400">
        {post.data.title}
      </h2>

      <p class="mb-4 line-clamp-2 text-sm text-gray-600 dark:text-gray-400">
        {post.data.description}
      </p>

      <time class="font-mono text-xs text-gray-400 dark:text-gray-500">
        {
          post.data.pubDate.toLocaleDateString("zh-CN", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </time>
    </div>
  </a>
</article>