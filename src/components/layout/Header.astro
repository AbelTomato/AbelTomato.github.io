---
import { SITE_TITLE } from "@src/consts";
import HeaderLink from "@components/layout/HeaderLink.astro";
import AboutMenu from "@components/layout/AboutMenu.astro";
---

<header
  id="main-header"
  class="sticky top-0 z-50 m-0 px-0 bg-white/70 dark:bg-gray-900/70 backdrop-blur-md shadow-[0_2px_8px_rgba(0,0,0,0.03)] dark:shadow-none transition-transform duration-300 ease-in-out"
>
  <nav class="flex items-center justify-between w-full px-6 lg:px-12 h-16">
    <h2 class="text-xl font-bold">
      <a
        href="/"
        class="flex items-center no-underline text-gray-900 dark:text-gray-100 hover:opacity-90 transition-opacity"
      >
        <img
          src="/android-chrome-512x512.png"
          alt="logo"
          class="h-8 w-auto mr-2 invert dark:invert-0 hover:rotate-12 transition-transform duration-300"
        />
        <span
          class="bg-linear-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-300 bg-clip-text text-transparent"
          >{SITE_TITLE}</span
        >
      </a>
    </h2>

    <div class="internal-links flex gap-6 h-full items-center">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/archive">Archive</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <AboutMenu />
      <HeaderLink href="/echo">Echo</HeaderLink>
      <HeaderLink href="/status">Status</HeaderLink>
    </div>

    <div class="social-links flex gap-4">
      <a
        href="https://github.com/AbelTomato"
        target="_blank"
        class="text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 transition-colors"
      >
        <span class="sr-only">Go to my GitHub homepage</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
      </a>

      <a
        href="mailto:abelmiaotomato@gmail.com"
        class="text-gray-600 dark:text-gray-400 hover:text-gray-800 dark:hover:text-gray-200 transition-colors"
      >
        <span class="sr-only">Email me</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          width="32"
          height="32"
        >
          <path
            d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"
          ></path>
          <path
            d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"
          ></path>
        </svg>
      </a>
    </div>
  </nav>
</header>

<style is:global>
  .internal-links > a,
  .internal-links .about-menu__trigger {
    position: relative;
    text-decoration: none;
    border-bottom: 4px solid transparent !important;
  }

  .internal-links > a::after,
  .internal-links .about-menu__trigger::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 3px;
    bottom: 0;
    left: 0;
    background-color: #3b82f6;
    transform: scaleX(0);
    transform-origin: bottom right;
    transition: transform 0.25s ease-out;
  }

  .internal-links > a:hover::after,
  .internal-links .about-menu__trigger:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  .internal-links > a.active,
  .internal-links .about-menu__trigger.active {
    color: #3b82f6 !important;
  }
  .internal-links > a.active::after,
  .internal-links .about-menu__trigger.active::after {
    transform: scaleX(1);
    background-color: #3b82f6;
  }
</style>

<script>
  const initHeaderScroll = () => {
    let lastScrollY = window.scrollY;
    let ticking = false;
    const header = document.getElementById("main-header");
    if (!header) return;

    window.__cleanupHeaderScroll?.();

    header.style.transform = "translateY(0)";

    const handleScroll = () => {
      if (ticking) return;

      ticking = true;
      window.requestAnimationFrame(() => {
        const currentScrollY = window.scrollY;

        if (currentScrollY > lastScrollY && currentScrollY > 150) {
          header.style.transform = "translateY(-100%)";
        } else {
          header.style.transform = "translateY(0)";
        }

        lastScrollY = currentScrollY;
        ticking = false;
      });
    };

    window.addEventListener("scroll", handleScroll, { passive: true });

    window.__cleanupHeaderScroll = () => {
      window.removeEventListener("scroll", handleScroll);
    };
  };

  initHeaderScroll();
  document.addEventListener("astro:page-load", initHeaderScroll);
</script>
