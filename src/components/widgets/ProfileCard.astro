---
import avatar from "@assets/images/common/喵喵.jpg";

const skills = ["React", "TypeScript", "C++", "Tailwind"];
---

<div
  class="max-w-sm mx-auto bg-slate-900 border border-slate-800 rounded-2xl shadow-xl overflow-hidden backdrop-blur-md hover:border-indigo-500/50 transition-all duration-300 group"
>
  <div class="h-2 bg-linear-to-r from-cyan-500 via-indigo-500 to-purple-500">
  </div>

  <div class="p-6 flex flex-col items-center text-center">
    <div
      class="relative w-24 h-24 mb-4 rounded-full p-1 bg-linear-to-tr from-cyan-500 to-purple-500 group-hover:scale-105 transition-transform duration-300"
    >
      <img
        src={avatar.src}
        alt="头像"
        class="w-full h-full object-cover rounded-full bg-slate-800"
      />
      <span
        class="absolute bottom-1 right-1 w-4 h-4 bg-green-500 border-2 border-slate-900 rounded-full animate-pulse"
      ></span>
    </div>

    <h2 class="text-2xl font-bold text-slate-100 tracking-wide">AbelTomato</h2>
    <p
      class="text-xs text-indigo-400 font-medium mt-1 uppercase tracking-widest"
    >
      Time tries all, but TLE.
    </p>

    <p class="text-sm text-slate-400 mt-3 leading-relaxed max-w-xs">
      末9大一计算机在读。当前目标是成为一名优秀的全栈工程师，目前正在学习React。爱好看小说，打游戏，偶尔运动
    </p>

    <hr class="w-full border-slate-800 my-4" />

    <div class="w-full text-left">
      <h3
        class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2"
      >
        Technical Skills
      </h3>
      <div class="flex flex-wrap gap-1.5">
        {
          skills.map((skill) => (
            <span class="px-2.5 py-1 text-xs font-medium rounded-md bg-slate-800 text-slate-300 border border-slate-700/50 hover:border-indigo-500/30 hover:text-indigo-300 transition-colors cursor-default">
              {skill}
            </span>
          ))
        }
      </div>
    </div>

    <hr class="w-full border-slate-800 my-4" />

    <div class="w-full grid grid-cols-3 gap-2 text-sm font-medium">
      <a
        href="https://github.com/AbelTomato"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center py-2 rounded-lg bg-slate-800/50 border border-slate-700/50 text-slate-300 hover:bg-slate-800 hover:text-white hover:border-slate-600 transition-all"
      >
        <span class="text-xs">GitHub</span>
      </a>

      <a
        href="https://www.luogu.com.cn/user/561297"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center py-2 rounded-lg bg-slate-800/50 border border-slate-700/50 text-slate-300 hover:bg-emerald-950/40 hover:text-emerald-400 hover:border-emerald-500/40 transition-all"
      >
        <span class="text-xs">洛谷</span>
      </a>

      <a
        href="https://space.bilibili.com/512099551?spm_id_from=333.1007.0.0"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center py-2 rounded-lg bg-slate-800/50 border border-slate-700/50 text-slate-300 hover:bg-pink-950/40 hover:text-pink-400 hover:border-pink-500/40 transition-all"
      >
        <span class="text-xs">Bilibili</span>
      </a>
    </div>
  </div>
</div>
