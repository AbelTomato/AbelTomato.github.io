---
import avatar from "@assets/images/common/喵喵.jpg";

const skills = ["React", "TypeScript", "C++"];
---

<div
  class="max-w-sm mx-auto bg-white border border-slate-200 dark:bg-slate-900 dark:border-slate-800/80 rounded-2xl shadow-sm hover:shadow-md dark:shadow-none transition-all duration-300"
>
  <div class="p-6 flex flex-col items-center text-center">
    <div
      class="relative w-20 h-20 mb-4 rounded-full p-0.5 bg-slate-200 dark:bg-slate-800"
    >
      <img
        src={avatar.src}
        alt="头像"
        class="w-full h-full object-cover rounded-full"
      />
    </div>

    <h2
      class="text-xl font-bold text-slate-800 dark:text-slate-100 tracking-tight"
    >
      AbelTomato
    </h2>
    <p class="text-xs text-slate-400 dark:text-slate-500 font-mono mt-1">
      Time tries all, but TLE.
    </p>

    <p
      class="text-sm text-slate-600 dark:text-slate-400 mt-3 leading-relaxed max-w-xs"
    >
      末9大一计算机在读。正在学习React
    </p>

    <hr class="w-full border-slate-100 dark:border-slate-800/60 my-4" />

    <div class="w-full text-left">
      <h3
        class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-2"
      >
        Technical Skills
      </h3>
      <div class="flex flex-wrap gap-1.5">
        {
          skills.map((skill) => (
            <span class="px-2.5 py-1 text-xs font-medium rounded-md bg-slate-50 border border-slate-200 text-slate-600 dark:bg-slate-800/50 dark:border-slate-700/50 dark:text-slate-300 cursor-default">
              {skill}
            </span>
          ))
        }
      </div>
    </div>

    <hr class="w-full border-slate-100 dark:border-slate-800/60 my-4" />

    <div class="w-full grid grid-cols-3 gap-2 text-sm font-medium">
      <a
        href="https://github.com/AbelTomato"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center py-2 rounded-lg bg-slate-50 border border-slate-200 text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:bg-slate-800/40 dark:border-slate-700/50 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white transition-all"
      >
        <span class="text-xs">GitHub</span>
      </a>

      <a
        href="https://www.luogu.com.cn/user/561297"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center py-2 rounded-lg bg-slate-50 border border-slate-200 text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:bg-slate-800/40 dark:border-slate-700/50 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white transition-all"
      >
        <span class="text-xs">洛谷</span>
      </a>

      <a
        href="https://space.bilibili.com/512099551?spm_id_from=333.1007.0.0"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center py-2 rounded-lg bg-slate-50 border border-slate-200 text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:bg-slate-800/40 dark:border-slate-700/50 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white transition-all"
      >
        <span class="text-xs">Bilibili</span>
      </a>
    </div>
  </div>
</div>
