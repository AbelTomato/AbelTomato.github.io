---
import avatar from "@assets/images/common/喵喵.jpg";
---

<div
  class="mx-auto w-full max-w-sm rounded-xl border border-zinc-200/60 bg-white/45 shadow-sm backdrop-blur-xl transition-all duration-300 hover:shadow-md dark:border-zinc-700/60 dark:bg-zinc-900/45 dark:shadow-none"
>
  <div class="p-6 flex flex-col items-center text-center">
    <div
      class="relative mb-4 h-20 w-20 rounded-full bg-blue-100 p-0.5 dark:bg-blue-950/60"
    >
      <img
        src={avatar.src}
        alt="头像"
        class="h-full w-full rounded-full border-2 border-white object-cover dark:border-zinc-900"
      />
    </div>

    <h2
      class="text-xl font-bold tracking-tight text-zinc-800 dark:text-zinc-100"
    >
      AbelTomato
    </h2>
    <p class="mt-1 font-mono text-xs text-zinc-400 dark:text-zinc-500">
      Time tries all, but TLE.
    </p>

    <p
      class="mt-3 max-w-xs text-sm leading-relaxed text-zinc-600 dark:text-zinc-400"
    >
      末9大一计算机在读。正在学习React
    </p>

    <hr class="my-4 w-full border-zinc-100 dark:border-zinc-800" />

    <div class="w-full grid grid-cols-2 gap-2 text-sm font-medium">
      <a
        href="https://github.com/AbelTomato"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center rounded-lg border border-zinc-100 bg-zinc-50 py-2 text-zinc-600 transition-all hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 dark:border-zinc-800 dark:bg-zinc-800/40 dark:text-zinc-300 dark:hover:border-blue-900/60 dark:hover:bg-blue-950/30 dark:hover:text-blue-300"
      >
        <span class="text-xs">GitHub</span>
      </a>

      <a
        href="https://space.bilibili.com/512099551?spm_id_from=333.1007.0.0"
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center rounded-lg border border-zinc-100 bg-zinc-50 py-2 text-zinc-600 transition-all hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 dark:border-zinc-800 dark:bg-zinc-800/40 dark:text-zinc-300 dark:hover:border-blue-900/60 dark:hover:bg-blue-950/30 dark:hover:text-blue-300"
      >
        <span class="text-xs">Bilibili</span>
      </a>
    </div>
  </div>
</div>
