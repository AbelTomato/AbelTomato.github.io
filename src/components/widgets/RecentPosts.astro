---
import type { CollectionEntry } from "astro:content";
import RecentPostCard from "@components/widgets/RecentPostCard.astro";
import { ArrowRevealButton } from "@components/ui/ArrowRevealButton";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

<section class="mb-16">
  <div class="mb-8 flex items-center justify-between">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
      最近文章
    </h2>

    <ArrowRevealButton href="/blog/" className="h-10 w-40 text-xs">
      查看全部
    </ArrowRevealButton>
  </div>

  {
    posts.length > 0 ? (
      <div class="flex flex-col gap-4">
        {posts.map((post) => (
          <RecentPostCard post={post} />
        ))}
      </div>
    ) : (
      <div class="rounded-xl border border-gray-200 bg-white p-8 text-center text-sm text-muted-foreground dark:border-gray-700 dark:bg-gray-800/50">
        暂无文章
      </div>
    )
  }
</section>
